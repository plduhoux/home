# MIME types
AddType application/wasm .wasm
AddType application/javascript .js
AddType application/json .json

# Compression gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Cache longue durée
<IfModule mod_expires.c>
  ExpiresActive On

  # Assets avec hash dans le nom (Nuxt _nuxt/) : 1 an
  <FilesMatch "\.(js|css|wasm)$">
    ExpiresDefault "access plus 1 year"
  </FilesMatch>

  # Images : 1 mois
  <FilesMatch "\.(png|jpg|jpeg|webp|gif|svg|ico)$">
    ExpiresDefault "access plus 1 month"
  </FilesMatch>

  # Fonts : 1 an
  <FilesMatch "\.(woff|woff2|ttf|eot)$">
    ExpiresDefault "access plus 1 year"
  </FilesMatch>

  # HTML/JSON : 1 heure (pour les mises à jour)
  <FilesMatch "\.(html|json)$">
    ExpiresDefault "access plus 1 hour"
  </FilesMatch>
</IfModule>

# Headers Cache-Control en fallback
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|wasm|woff|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(png|jpg|jpeg|webp|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  <FilesMatch "\.(html|json)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>
